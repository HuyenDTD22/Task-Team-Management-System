# ──────────────────────────────────────────────────────────────────────────────
# Dev profile template — safe to commit (no real secrets)
#
# Setup:
#   cp application-dev.yml.example application-dev.yml
#   Fill in YOUR values in application-dev.yml
#   application-dev.yml is gitignored — never commit it
# ──────────────────────────────────────────────────────────────────────────────
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/taskmanager
    username: postgres
    password: <your-local-db-password>
    hikari:
      maximum-pool-size: 5
      pool-name: TaskManagerHikariPool-Dev
  jpa:
    properties:
      hibernate:
        format_sql: true

app:
  cookie-secure: false

cloudinary:
  cloud-name: <your-cloudinary-cloud-name>
  api-key: <your-cloudinary-api-key>
  api-secret: <your-cloudinary-api-secret>

logging:
  level:
    com.taskmanager: DEBUG
    org.hibernate.SQL: DEBUG
    org.springframework.security: DEBUG
