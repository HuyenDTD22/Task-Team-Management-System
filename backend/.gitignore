# ──────────────────────────────────────────────────────────────────────────────
# Backend .gitignore
# Rule: .example files → COMMIT (safe templates)
#       actual credential files → NEVER COMMIT
# ──────────────────────────────────────────────────────────────────────────────

# ── Maven build output ────────────────────────────────────────────────────────
target/
!**/src/main/**/target/
!**/src/test/**/target/
HELP.md

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
/nbproject/private/
/.nb-gradle/

# ── Sensitive Spring config — NEVER COMMIT ────────────────────────────────────
# These files contain real credentials (DB password, API keys).
# Copy application-dev.yml.example → application-dev.yml and fill in values.
src/main/resources/application-dev.yml
src/main/resources/application-local.yml
