# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for environment variables
# Copy to .env and fill in real values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Database (PostgreSQL container) ──────────────────────────────────────────
DB_NAME=taskmanager
DB_USERNAME=taskmanager_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Used by Spring Boot (must point to the postgres service name in Docker network)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/taskmanager
SPRING_DATASOURCE_USERNAME=taskmanager_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_AT_LEAST_64_CHARS
JWT_ACCESS_TOKEN_EXPIRY=1800000     # 30 minutes (ms)
JWT_REFRESH_TOKEN_EXPIRY=604800000  # 7 days (ms)

# ── Application ───────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
