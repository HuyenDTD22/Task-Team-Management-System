# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template biến môi trường cho production deployment
#
# CÁCH DÙNG:
#   cp .env.example .env
#   nano .env        # Điền tất cả giá trị "CHANGE_ME_..."
#
# RULES:
#   ✅ COMMIT file này   (.env.example — không chứa secret thật, an toàn)
#   ❌ KHÔNG COMMIT .env (chứa secret thật)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Dùng chung cho cả postgres service và backend service
POSTGRES_DB=taskmanager
POSTGRES_USER=taskmanager_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── JWT Authentication ────────────────────────────────────────────────────────
# Phải đủ 256 bit (32 bytes) sau khi base64-decode.
# Tạo bằng: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# ── Cloudinary (lưu trữ avatar và file upload) ────────────────────────────────
# Lấy tại: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=CHANGE_ME_your_cloud_name
CLOUDINARY_API_KEY=CHANGE_ME_your_api_key
CLOUDINARY_API_SECRET=CHANGE_ME_your_api_secret

# ── Application ───────────────────────────────────────────────────────────────
# URL frontend — dùng cho CORS config trong Spring Boot (app.frontend-url)
# HTTP only (không có domain): http://<EC2_PUBLIC_IP>
# Ví dụ: http://13.215.12.34
FRONTEND_URL=http://CHANGE_ME_EC2_PUBLIC_IP

# ── GitHub Container Registry ────────────────────────────────────────────────
# GitHub username của bạn — dùng trong image path và docker login trên EC2
GHCR_USERNAME=CHANGE_ME_your_github_username

# ── Docker Image Tag ──────────────────────────────────────────────────────────
# Để 'latest' cho auto-latest sau mỗi CI deploy.
# Rollback: đặt thành 'sha-abc1234' rồi chạy: docker compose up -d --remove-orphans
IMAGE_TAG=latest
